echo "=== 8. Настройка политик брандмауэра SELinux и Firewall ==="
# Разрешаем веб-серверу работать с сетью и портами, если включен SELinux
if selinuxenabled 2>/dev/null; then
    setsebool -P httpd_can_network_connect 1 || true
    setsebool -P httpd_builtin_scripting 1 || true
    chcon -R -t httpd_sys_rw_content_t /var/www/html/uploads || true
fi

# Открываем порт 80 в Firewall, если сервис активен
if systemctl is-active --quiet firewalld; then
    firewall-cmd --permanent --add-service=http
    firewall-cmd --reload
fi

