#!/bin/bash

# Полностью автономный скрипт без вызовов PHP в консоли
set -e

echo "=== 1. Чистка старых конфликтов и обновление ==="
yum remove -y php php-cli php-common || true
yum update -y
yum install -y epel-release yum-utils

echo "=== 2. Подключение Remi и принудительная установка PHP 7.4 ==="
yum install -y http://rpms.remirepo.net/enterprise/remi-release-7.rpm
yum-config-manager --enable remi-php7.4
yum install -y php php-pdo php-mysqlnd php-openssl php-mbstring php-xml -y

echo "=== 3. Установка Apache и MariaDB ==="
yum install -y httpd mariadb-server mariadb
systemctl enable httpd mariadb
systemctl start httpd mariadb

echo "=== 4. Создание базы данных и таблиц ==="
mysql -u root -e "CREATE DATABASE IF NOT EXISTS file_storage CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;"

mysql -u root -e "
USE file_storage;
CREATE TABLE IF NOT EXISTS users (
    id INT AUTO_INCREMENT PRIMARY KEY,
    username VARCHAR(50) NOT NULL UNIQUE,
    password_hash VARCHAR(255) NOT NULL
) ENGINE=InnoDB;

CREATE TABLE IF NOT EXISTS files (
    id INT AUTO_INCREMENT PRIMARY KEY,
    user_id INT NOT NULL,
    description TEXT,
    file_path VARCHAR(255) NOT NULL,
    file_name VARCHAR(255) NOT NULL,
    file_size INT NOT NULL,
    file_type VARCHAR(100),
    FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE
) ENGINE=InnoDB;"

echo "=== 5. Добавление админа (хэш сгенерирован заранее во избежание ошибок PHP) ==="
# Это готовый валидный хэш для пароля 'password' по алгоритму BCRYPT
HARDCODED_HASH='$2y$10$4v7g29/g.0XzW3hFzS36e.vX.HlyrWIDh6UaIeSOfOIQ6LgKkG19W'

mysql -u root -e "
USE file_storage;
INSERT IGNORE INTO users (id, username, password_hash) VALUES (1, 'admin', '${HARDCODED_HASH}');"

echo "=== 6. Создание папок и прав ==="
mkdir -p /var/www/html/uploads
chown -R apache:apache /var/www/html/
chmod -R 755 /var/www/html/

echo "=== 7. Запись index.php ==="
cat << 'EOF' > /var/www/html/index.php
<?php
session_start();

$host = 'localhost';
$dbname = 'file_storage';
$user = 'root';
$pass = '';

try {
    $pdo = new PDO("mysql:host=$host;dbname=$dbname;charset=utf8mb4", $user, $pass);
    $pdo->setAttribute(PDO::ATTR_ERRMODE, PDO::ERRMODE_EXCEPTION);
    $pdo->setAttribute(PDO::ATTR_DEFAULT_FETCH_MODE, PDO::FETCH_ASSOC);
} catch (PDOException $e) {
    die("Ошибка БД: " . $e->getMessage());
}

function encryptFile($fileData, $key) {
    $iv = openssl_random_pseudo_bytes(16);
    $encrypted = openssl_encrypt($fileData, 'AES-256-CBC', $key, OPENSSL_RAW_DATA, $iv);
    return base64_encode($iv . $encrypted);
}

function decryptFile($encryptedData, $key) {
    $data = base64_decode($encryptedData);
    $iv = substr($data, 0, 16);
    $encrypted = substr($data, 16);
    return openssl_decrypt($encrypted, 'AES-256-CBC', $key, OPENSSL_RAW_DATA, $iv);
}

$message = '';
$messageType = '';

if (isset($_GET['logout'])) {
    session_destroy();
    header('Location: index.php');
    exit;
}

if ($_SERVER['REQUEST_METHOD'] === 'POST' && isset($_FILES['file'])) {
    if (!isset($_SESSION['user_id'])) {
        $message = 'Авторизуйтесь!';
        $messageType = 'danger';
    } elseif (empty($_POST['key'])) {
        $message = 'Введите ключ!';
        $messageType = 'warning';
    } else {
        $uploadDir = 'uploads/' . $_SESSION['user_id'] . '/';
        if (!file_exists($uploadDir)) mkdir($uploadDir, 0777, true);
        
        $fileName = time() . '_' . basename($_FILES['file']['name']);
        $filePath = $uploadDir . $fileName;
        
        $fileData = file_get_contents($_FILES['file']['tmp_name']);
        $encryptedData = encryptFile($fileData, $_POST['key']);
        file_put_contents($filePath, $encryptedData);
        
        $stmt = $pdo->prepare("INSERT INTO files (user_id, description, file_path, file_name, file_size, file_type) VALUES (?, ?, ?, ?, ?, ?)");
        $stmt->execute([$_SESSION['user_id'], $_POST['description'], $filePath, $_FILES['file']['name'], $_FILES['file']['size'], $_FILES['file']['type']]);
        $message = 'Файл зашифрован и сохранен!'; $messageType = 'success';
    }
}

if (isset($_GET['delete']) && isset($_SESSION['user_id'])) {
    $stmt = $pdo->prepare("SELECT file_path FROM files WHERE id = ? AND user_id = ?");
    $stmt->execute([$_GET['delete'], $_SESSION['user_id']]);
    $file = $stmt->fetch();
    if ($file) {
        if (file_exists($file['file_path'])) unlink($file['file_path']);
        $stmt = $pdo->prepare("DELETE FROM files WHERE id = ? AND user_id = ?");
        $stmt->execute([$_GET['delete'], $_SESSION['user_id']]);
    }
    header('Location: index.php'); exit;
}

if (isset($_GET['download_decrypted']) && isset($_SESSION['user_id']) && $_SERVER['REQUEST_METHOD'] === 'POST') {
    $stmt = $pdo->prepare("SELECT * FROM files WHERE id = ? AND user_id = ?");
    $stmt->execute([$_GET['download_decrypted'], $_SESSION['user_id']]);
    $file = $stmt->fetch();
    if ($file && file_exists($file['file_path'])) {
        $decrypted = decryptFile(file_get_contents($file['file_path']), $_POST['decrypt_key']);
        if ($decrypted !== false) {
            header('Content-Type: ' . $file['file_type']);
            header('Content-Disposition: attachment; filename="' . $file['file_name'] . '"');
            echo $decrypted; exit;
        }
        $message = 'Неверный ключ!'; $messageType = 'danger';
    }
}

if ($_SERVER['REQUEST_METHOD'] === 'POST' && isset($_POST['username'])) {
    $stmt = $pdo->prepare("SELECT * FROM users WHERE username = ?");
    $stmt->execute([trim($_POST['username'])]);
    $user = $stmt->fetch();
    if ($user && password_verify($_POST['password'], $user['password_hash'])) {
        $_SESSION['user_id'] = $user['id'];
        $_SESSION['username'] = $user['username'];
        header('Location: index.php'); exit;
    }
    $message = 'Неверный логин/пароль'; $messageType = 'danger';
}
?>
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>Шифрованное хранилище</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light p-5">
<div class="container" style="max-width: 800px;">
    <?php if ($message): ?>
        <div class="alert alert-<?= $messageType ?>"><?= $message ?></div>
    <?php endif; ?>

    <?php if (!isset($_SESSION['user_id'])): ?>
        <div class="card p-4 mx-auto" style="max-width: 400px;">
            <h4>Вход в систему</h4>
            <form method="POST">
                <div class="mb-3"><label>Логин</label><input type="text" name="username" class="form-control" required></div>
                <div class="mb-3"><label>Пароль</label><input type="password" name="password" class="form-control" required></div>
                <button class="btn btn-primary w-100">Войти</button>
            </form>
        </div>
    <?php else: ?>
        <div class="d-flex justify-bin-between align-items-center mb-4">
            <h4>Привет, <?= htmlspecialchars($_SESSION['username']) ?></h4>
            <a href="index.php?logout=1" class="btn btn-sm btn-danger">Выйти</a>
        </div>

        <?php if (isset($_GET['download_decrypted'])): ?>
            <div class="card p-3 mb-4 border-warning">
                <form method="POST">
                    <label>Ключ для расшифровки:</label>
                    <input type="password" name="decrypt_key" class="form-control mb-2" required>
                    <button class="btn btn-success btn-sm">Скачать файл</button>
                </form>
            </div>
        <?php endif; ?>

        <div class="card p-4 mb-4">
            <h5>Загрузить файл</h5>
            <form method="POST" enctype="multipart/form-data">
                <div class="mb-2"><input type="file" name="file" class="form-control" required></div>
                <div class="mb-2"><input type="password" name="key" class="form-control" placeholder="Ключ AES-256" required></div>
                <div class="mb-2"><input type="text" name="description" class="form-control" placeholder="Описание"></div>
                <button class="btn btn-primary">Загрузить зашифрованным</button>
            </form>
        </div>

        <div class="card p-4">
            <h5>Ваши файлы</h5>
            <?php
            $stmt = $pdo->prepare("SELECT * FROM files WHERE user_id = ?");
            $stmt->execute([$_SESSION['user_id']]);
            foreach ($stmt->fetchAll() as $f): ?>
                <div class="d-flex justify-content-between align-items-center border-bottom py-2">
                    <div><strong><?= htmlspecialchars($f['file_name']) ?></strong> <small class="text-muted">(<?= htmlspecialchars($f['description']) ?>)</small></div>
                    <div class="btn-group">
                        <a href="index.php?download_decrypted=<?= $f['id'] ?>" class="btn btn-sm btn-success">Открыть</a>
                        <a href="index.php?delete=<?= $f['id'] ?>" class="btn btn-sm btn-danger">Удалить</a>
                    </div>
                </div>
            <?php endforeach; ?>
        </div>
    <?php endif; ?>
</div>
</body>
</html>
EOF

echo "=== 8. Фикс Firewall ==="
if systemctl is-active --quiet firewalld; then
    firewall-cmd --permanent --add-service=http && firewall-cmd --reload
fi

echo "Скрипт отработал! Логин: admin | Пароль: password"
